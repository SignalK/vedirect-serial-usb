{
  "name": "@signalk/vedirect-serial-usb",
  "version": "1.5.0",
  "description": "Signal K Node.js server plugin to read VE.Direct data via serial USB",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./standalone": {
      "types": "./dist/standalone.d.ts",
      "require": "./dist/standalone.js",
      "default": "./dist/standalone.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "logo.svg",
    "docs/screenshots",
    "README.md",
    "LICENSE"
  ],
  "signalk": {
    "displayName": "Victron VE.Direct",
    "appIcon": "./logo.svg",
    "screenshots": [
      "./docs/screenshots/1_config.png"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "mutation": "stryker run",
    "prettier:check": "prettier --check .",
    "prettier": "prettier --write .",
    "format": "npm run prettier",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin"
  ],
  "author": "Joachim Bakke <github@heiamoss.com> & Fabian Tollenaar <fabian@decipher.industries> (https://decipher.industries)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/SignalK/vedirect-serial-usb#readme",
  "bugs": {
    "url": "https://github.com/SignalK/vedirect-serial-usb/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SignalK/vedirect-serial-usb"
  },
  "dependencies": {
    "@serialport/parser-delimiter": "^13.0.0",
    "debug": "^4.4.3",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/mocha-runner": "^9.6.1",
    "@types/chai": "^4.3.20",
    "@types/debug": "^4.1.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.2",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.1",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "c8": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "test/**",
      "coverage/**",
      "dist/**",
      "src/types.ts"
    ],
    "all": true,
    "reporter": [
      "text",
      "lcov"
    ]
  }
}
